                spark.sql(f"""

                INSERT INTO meta.TaskQueue

                VALUES (

                    {TASK_ID},

                    {RUN_ID},

                    {CONFIG_ID},

                    {row.TaskConfigId},

                    '{safe_task_name}',

                    '{SOURCE_TYPE}',

                    '{safe_target_table}',


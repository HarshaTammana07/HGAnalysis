        CONNECTION_CONFIG
    )

    headers = build_dynamic_headers(
        connection_config
    )

    auth_object = build_auth_object(
        connection_config
    )
        
    # ==========================================
    # READ TASK CONFIG
    # ==========================================

    task_df = spark.sql(f"""

    SELECT *

    FROM meta.TaskConfig

    WHERE ConfigId = {CONFIG_ID}

    AND IsActive = 1

    ORDER BY ExecutionOrder

    """)

    task_configs = task_df.collect()

    # ==========================================
    # VALIDATE TASK CONFIG
    # ==========================================

    if not task_configs:

        raise Exception(
            "No active task config found"
        )

    # ==========================================
    # CHECK FAILED RUN
    # ==========================================

    failed_run_df = spark.sql(f"""

    SELECT DISTINCT failed_tq.RunId

    FROM meta.TaskQueue failed_tq

    WHERE failed_tq.ConfigId = {CONFIG_ID}

    AND failed_tq.Status IN (

        'FAILED',

        'SKIPPED'

    )

    AND NOT EXISTS (

        SELECT 1

        FROM meta.TaskQueue success_tq

        WHERE success_tq.RunId =
            failed_tq.RunId

        AND success_tq.TaskConfigId =
            failed_tq.TaskConfigId

        AND success_tq.Status = 'SUCCESS'

    )

    ORDER BY failed_tq.RunId DESC

    LIMIT 1

    """)

    failed_runs = failed_run_df.collect()

    # ==========================================
    # RESTART MODE
    # ==========================================

    if len(failed_runs) > 0:

        RUN_ID = failed_runs[0]["RunId"]

        restart_flag = 1

        attempt_number_df = spark.sql(f"""

        SELECT COALESCE(
            MAX(AttemptNumber),
            0
        )

        FROM meta.PipelineRun

        WHERE RunId = {RUN_ID}

        """)

        pipeline_attempt_number  = (
            attempt_number_df.collect()[0][0]
        ) + 1

        print("=" * 70)

        print(
            f"RESTARTING FAILED RUN : "
            f"{RUN_ID}"
        )

        print(
            f"ATTEMPT NUMBER : "
            f"{pipeline_attempt_number}"
        )

        print("=" * 70)

    else:


                dependency_rows[0]["Status"]
                != "SUCCESS"

            )

            if dependency_failed:

                TASK_ID = int(

                    datetime.now().strftime(
                        "%Y%m%d%H%M%S%f"
                    )[:18]

                )

                AUDIT_ID = int(

                    datetime.now().strftime(
                        "%Y%m%d%H%M%S%f"
                    )[:18]


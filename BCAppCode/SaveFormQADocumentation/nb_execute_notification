                    f"FINAL HEADERS : {task_headers}"
                )

                request_body = build_request_body(
                
                    connection_config,

                    row.RequestBody

                )

                print(
                    f"REQUEST BODY : "
                    f"{request_body}"
                )

                print(
                    f"AUTH TYPE : "
                    f"{type(task_auth_object)}"
                )

                response = fetch_api_data(

                    url=row.Endpoint,

                    method=row.Method,

                    headers=task_headers,

                    auth_object=task_auth_object,

                    request_body=request_body,

                    pagination_enabled=row.PaginationEnabled,

                    pagination_param=row.PaginationParam,

                    timeout_seconds=row.TimeoutSeconds,

                    retry_count=row.RetryCount

                )

                records = response["records"]

                rows_processed = (
                    response["rows_processed"]
                )

                api_response_time_ms = (
                    response[
                        "api_response_time_ms"
                    ]
                )

                http_status_code = (
                    response[
                        "http_status_code"
                    ]
                )

                retry_attempt = (
                    response[
                        "retry_attempt"
                    ]
                )

                df = create_spark_df(records)

                if df is None:
                
                    rows_processed = 0

            # ==================================
            # TABLE SOURCE
            # ==================================

            elif SOURCE_TYPE.upper() == "TABLE":
                print("TABLE SOURCE LOGIC V2")
                print(f"Source Table = {row.SourceTable}")
                print(
                    f"Exists = "
                    f"{spark.catalog.tableExists(row.SourceTable)}"
                )
            
                if not spark.catalog.tableExists(
                    row.SourceTable
                ):
            
                    print(
                        f"Source table not found : "
                        f"{row.SourceTable}"
                    )
            
                    rows_processed = 0
            
                else:
                
                    df = read_source_table(
                        row.SourceTable
                    )
            
                    rows_processed = df.count()

                retry_attempt = 0

                api_response_time_ms = 0

                http_status_code = 0

            else:

                raise Exception(

                    f"Unsupported SourceType : "
                    f"{SOURCE_TYPE}"

                )

            # ==================================
            # EMPTY SOURCE
            # ==================================

            if rows_processed == 0:
            
                print(
                    f"No records returned : "
                    f"{row.TaskName}"
                )
            
                rows_written = 0
            
                spark.sql(f"""
            
                UPDATE meta.TaskQueue
            
                SET
            
                    ExecutionFlag = 1,
            
                    Status = 'SUCCESS',
            

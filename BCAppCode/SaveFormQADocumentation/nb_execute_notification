            )[:18]

        )

        # ======================================
        # INSERT TASKQUEUE
        # ======================================
        attempt_number = spark.sql(f"""

        SELECT COALESCE(
            MAX(AttemptNumber),
            0
        )

        FROM meta.TaskQueue

        WHERE RunId = {RUN_ID}

        AND TaskConfigId =
            {row.TaskConfigId}

        """).collect()[0][0] + 1

        spark.sql(f"""

        INSERT INTO meta.TaskQueue

        VALUES (

            {TASK_ID},

            {RUN_ID},

            {CONFIG_ID},

            {row.TaskConfigId},

            '{safe_task_name}',

            '{SOURCE_TYPE}',

            '{safe_target_table}',

            {row.ExecutionOrder},

            0,

            'RUNNING',

            0,

            {restart_flag},

            {attempt_number},

            0,

            0,

            current_timestamp(),

            NULL,

            NULL,

            current_timestamp(),

            NULL,

            NULL,

            NULL

            )

            """)

        # ======================================
        # TASK START TIME
        # ======================================

        task_start_time = spark.sql(f"""

        SELECT StartTime

        FROM meta.TaskQueue

        WHERE TaskId = {TASK_ID}

        """).collect()[0][0]

        retry_attempt = 0

        http_status_code = 0
        
        api_response_time_ms = 0

        df = None

        try:

            print("=" * 70)

            print(
                f"EXECUTING : "
                f"{row.TaskName}"
            )

            print("=" * 70)

            # ==================================
            # API SOURCE
            # ==================================

            task_headers = dict(headers)

            if (
                hasattr(row, "RequestHeaders")
                and
                row.RequestHeaders
            ):

                task_headers.update(
                    json.loads(
                        row.RequestHeaders
                    )
                )

            if SOURCE_TYPE.upper() == "API":

                task_auth_object = auth_object

                if (
                
                    hasattr(row, "AuthType")

                    and


        0,

        0,

        0,

        {restart_flag},

        {pipeline_attempt_number},

        current_timestamp()

    )

    """)

    # ==========================================
    # FAILURE TRACKER
    # ==========================================

    pipeline_failures = []

    pipeline_successes = [] # Success tracker for Teams alert

    # ==========================================
    # EXECUTE TASKS
    # ==========================================

    for row in task_configs:

        safe_task_name = (
            row.TaskName.replace(
                "'",
                "''"
            )
        )

        safe_target_table = (
            row.TargetTable.replace(
                "'",
                "''"

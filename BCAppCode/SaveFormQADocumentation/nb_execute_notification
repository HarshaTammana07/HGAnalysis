            # ==================================

            if TARGET_NAME.upper() == "GL":

                write_gold_table(

                    df=df,

                    table_name=full_table_name,

                    load_type=row.LoadType

                )

            else:

                write_delta(

                    df=df,

                    table_name=full_table_name,

                    load_type=row.LoadType

                )
            
            df.unpersist(blocking=True)

            # ==================================
            # UPDATE TASKQUEUE
            # ==================================

            spark.sql(f"""

            UPDATE meta.TaskQueue

            SET

                ExecutionFlag = 1,

                Status = 'SUCCESS',

                RetryAttempt =
                    {retry_attempt},

                HttpStatusCode =
                    {http_status_code},

                ApiResponseTimeMs =
                    {api_response_time_ms},

                EndTime =
                    current_timestamp(),

                ErrorMessage = NULL

            WHERE TaskId = {TASK_ID}

            """)

            # ==================================
            # INSERT TASK AUDIT
            # ==================================

            task_end_time = datetime.now()

            duration_seconds = (
                calculate_duration_seconds(
                    task_start_time,
                    task_end_time
                )
            )

            spark.sql(f"""

            INSERT INTO meta.TaskAudit

            VALUES (

                {AUDIT_ID},

                {TASK_ID},


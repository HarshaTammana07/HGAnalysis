        raise Exception(
            "PIPELINE_NAME variable not defined"
        )

    # ==========================================
    # SAFE PIPELINE NAME
    # ==========================================

    SAFE_PIPELINE_NAME = (
        PIPELINE_NAME.replace("'", "''")
    )

    # ==========================================
    # READ ETL CONFIG
    # ==========================================

    config_df = spark.sql(f"""

    SELECT *

    FROM meta.EtlConfig

    WHERE UPPER(PipelineName) =
    UPPER('{SAFE_PIPELINE_NAME}')

    AND IsActive = 1

    """)

    configs = config_df.collect()

    # ==========================================
    # VALIDATE CONFIG
    # ==========================================

    if not configs:

        raise Exception(

            f"No active config found "
            f"for {PIPELINE_NAME}"


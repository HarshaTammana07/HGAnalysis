        dependency_task_id = (
            row.DependencyTaskConfigId
        )

        if dependency_task_id is not None:

            dependency_df = spark.sql(f"""

            SELECT Status
            
            FROM meta.TaskQueue
            
            WHERE TaskConfigId =
                {dependency_task_id}
            
            AND Status IN (
            
                'SUCCESS',
            
                'FAILED',
            
                'SKIPPED'
            
            )
            
            ORDER BY RunId DESC,
                    CreatedAt DESC
            
            LIMIT 1

            """)

            dependency_rows = (
                dependency_df.collect()
            )

            dependency_failed = (

                len(dependency_rows) == 0


            print("=" * 100)

            print(type(e))
            print(str(e))

            traceback.print_exc()

            print("=" * 100)
            
            error_message = clean_sql_text(
                str(e)
            )

            pipeline_failures.append({
            
                "task": row.TaskName,

                "task_config_id": row.TaskConfigId,

                "error": error_message,

                "timestamp": datetime.now().strftime(
                    "%Y-%m-%d %H:%M:%S"
                )

            })

            spark.sql(f"""

            UPDATE meta.TaskQueue

            SET

                ExecutionFlag = 0,

                Status = 'FAILED',

                RetryAttempt =
                    {retry_attempt if 'retry_attempt' in locals() else 0},

                EndTime =
                    current_timestamp(),

                ErrorMessage =
                    '{error_message}'

            WHERE TaskId = {TASK_ID}

            """)
            
            task_end_time = datetime.now()

            duration_seconds = (
                calculate_duration_seconds(
                    task_start_time,
                    task_end_time
                )
            )

        
            spark.sql(f"""

            INSERT INTO meta.TaskAudit

            VALUES (

                {AUDIT_ID},

                {TASK_ID},

                {RUN_ID},

                {CONFIG_ID},

                {row.TaskConfigId},

                '{safe_task_name}',

                '{safe_target_table}',

                'TASK_FAILED',

                'FAILED',

                'ERROR',

                0,

                0,

                0,

                '{error_message}',

                TIMESTAMP('{task_start_time}'),

                current_timestamp(),

                {duration_seconds},

                current_timestamp(),

                NULL,

                NULL

            )

            """)

            print("=" * 70)

            print(
                f"FAILED : "
                f"{row.TaskName}"
            )

            print(
                f"ERROR : "
                f"{error_message}"
            )

            print("=" * 70)

            continue

    # ==========================================
    # FINAL COUNTS
    # ==========================================

    success_count = spark.sql(f"""

    SELECT COUNT(DISTINCT TaskConfigId)

    FROM meta.TaskQueue

    WHERE RunId = {RUN_ID}

    AND Status = 'SUCCESS'

    """).collect()[0][0]

    failed_count = spark.sql(f"""

    SELECT COUNT(DISTINCT TaskConfigId)

    FROM meta.TaskQueue failed_tq

    WHERE failed_tq.RunId = {RUN_ID}

    AND failed_tq.Status = 'FAILED'

    AND NOT EXISTS (

        SELECT 1

        FROM meta.TaskQueue success_tq

        WHERE success_tq.RunId =
            failed_tq.RunId

        AND success_tq.TaskConfigId =
            failed_tq.TaskConfigId

        AND success_tq.Status = 'SUCCESS'

    )

    """).collect()[0][0]

    skipped_count = spark.sql(f"""

    SELECT COUNT(DISTINCT TaskConfigId)

    FROM meta.TaskQueue

    WHERE RunId = {RUN_ID}

    AND Status = 'SKIPPED'

    """).collect()[0][0]

    final_pipeline_status = (

        "FAILED"

        if failed_count > 0

        else "SUCCESS"

    )

    # ==========================================
    # UPDATE PIPELINE RUN
    # ==========================================

    spark.sql(f"""

    UPDATE meta.PipelineRun

    SET

        EndTime = current_timestamp(),

        Status = '{final_pipeline_status}',

        SuccessTasks = {success_count},

        FailedTasks = {failed_count},

        SkippedTasks = {skipped_count}

    WHERE RunId = {RUN_ID}

    AND AttemptNumber = {pipeline_attempt_number}

    """)

    # ==========================================
    # FINAL STATUS
    # ==========================================

    print("=" * 70)

    print(
        f"PIPELINE STATUS : "
        f"{final_pipeline_status}"
    )

    print(
        f"SUCCESS TASKS : "
        f"{success_count}"
    )

    print(
        f"FAILED TASKS : "
        f"{failed_count}"
    )

    print(

        f"SKIPPED TASKS : "

        f"{skipped_count}"

    ) 
    print("=" * 70)

    # ==========================================
    # FAILED TASK SUMMARY
    # ==========================================

    if pipeline_failures:

        print("=" * 70)

        print("FAILED TASK SUMMARY")

        print("=" * 70)

        for failure in pipeline_failures:

            print(

                f"TASK : "
                f"{failure['task']} | "

                f"ERROR : "
                f"{failure['error']}"

            )

        print("=" * 70)

    # ==========================================================
    # SEND TEAMS NOTIFICATION
    # ==========================================================
    if final_pipeline_status == "FAILED":
        send_teams_failure_alert(
            pipeline_name=PIPELINE_NAME,
            config_name=CONFIG_NAME,
            source_system=SOURCE_SYSTEM,
            target_name=TARGET_NAME,
            environment_name=ENVIRONMENT_NAME,
            run_id=RUN_ID,
            failed_count=failed_count,
            failures=pipeline_failures
        )
    elif final_pipeline_status == "SUCCESS":
        
        send_teams_success_alert(
            pipeline_name=PIPELINE_NAME,
            config_name=CONFIG_NAME,
            source_system=SOURCE_SYSTEM,
            target_name=TARGET_NAME,
            environment_name=ENVIRONMENT_NAME,
            run_id=RUN_ID,
            success_count=success_count,
            successes=pipeline_successes
        )
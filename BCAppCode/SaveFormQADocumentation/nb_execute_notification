    def send_teams_failure_alert(
        pipeline_name,
        config_name,
        source_system,
        target_name,
        environment_name,
        run_id,
        failed_count,
        failures
    ):
        target_layer_map = {
        "BR": "Bronze",
        "SL": "Silver",
        "GL": "Gold"
        }

        target_layer = target_layer_map.get(
            str(target_name).upper(),
            str(target_name)
        )

        display_config_name = (
            str(config_name)
            .replace(" Pipeline", "")
            .replace(" pipeline", "")
        )

        failure_text = ""

        for idx, failure in enumerate(failures, start=1):
        
            failure_text += f"""

            Failure {idx}

            Task Config ID : {failure['task_config_id']}

            Task Name : {failure['task']}

            Error :
            {failure['error']}

            --------------------------------------------------

            """
        payload = {
            "@type": "MessageCard",
            "@context": "http://schema.org/extensions",
            "themeColor": "FF0000",
            "summary": f"Pipeline Failed - {pipeline_name}",
            "title": (
                f"{environment_name}: Failed - "
                f"{source_system} - "
                f"{target_layer} - "
                f"{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}"
            ),
            "sections": [
                {
                    "facts": [
                        {
                            "name": "Pipeline:",
                            "value": str(pipeline_name)
                        },
                        {
                            "name": "Config Name:",
                            "value": display_config_name
                        },
                        {
                            "name": "Run ID:",
                            "value": str(run_id)
                        },
                        {
                            "name": "Failed Tasks:",
                            "value": str(failed_count)
                        }
                    ]
                },
                {
                    "activityTitle": "Failure Details",
                    "text": failure_text[:12000]
                }
            ]
        }

        response = requests.post(
            WEBHOOK_URL,
            json=payload,
            headers={
                "Content-Type": "application/json"
            }
        )

        print(
            f"Teams Notification Status : "
            f"{response.status_code}"
        )
    
    def send_teams_success_alert(

                'SUCCESS',

                'INFO',

                {rows_processed},

                {rows_written},

                0,

                NULL,

                TIMESTAMP('{task_start_time}'),

                current_timestamp(),

                {duration_seconds},

                current_timestamp(),

                NULL,

                NULL

            )

            """)

            # ==================================
            # INSERT DQ
            # ==================================

            DQ_ID = int(

                datetime.now().strftime(
                    "%Y%m%d%H%M%S%f"

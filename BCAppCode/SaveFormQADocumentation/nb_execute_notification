        print(
            f"STARTING NEW RUN : "
            f"{RUN_ID}"
        )

        print(
            f"ATTEMPT NUMBER : "
            f"{pipeline_attempt_number}"
        )

        print("=" * 70)

    # ==========================================
    # INSERT PIPELINE RUN
    # ==========================================

                    'No records returned',
            
                    TIMESTAMP('{task_start_time}'),
            
                    current_timestamp(),
            
                    {duration_seconds},
            
                    current_timestamp(),

                    NULL,

                    NULL
            
                )
            
                """)
            
                DQ_ID = int(
                
                    datetime.now().strftime(
                        "%Y%m%d%H%M%S%f"
                    )[:18]
            
                )
            
                spark.sql(f"""
            
                INSERT INTO meta.DataQuality
            
                VALUES (
                
                    {DQ_ID},
            
                    {RUN_ID},
            
                    {CONFIG_ID},
            
                    {row.TaskConfigId},
            
                    '{safe_target_table}',
            
                    0,
            
                    0,
            
                    0,
            
                    'SUCCESS',
            
                    current_timestamp()
            
                )
            
                """)

                pipeline_successes.append({
                
                    "task": row.TaskName,
                
                    "task_config_id": row.TaskConfigId
                
                })
            
                continue

            # ==================================
            # CACHE DF
            # ==================================

            df = df.cache()

            source_count = df.count()

            dedup_df = df.dropDuplicates()

            dedup_count = dedup_df.count()

            duplicate_count = (
                source_count - dedup_count
            )

            # ==================================
            # SILVER DEDUP
            # ==================================

            if TARGET_NAME.upper() == "SL":
            
                df = dedup_df

                if SOURCE_SYSTEM.upper() == "UKG":
                    print(f"BEFORE TRANSFORMATION : {type(df)}")
                    df = apply_gold_transformations(
                        df=df,
                        target_table=row.TargetTable
                    )
                    print(f"AFTER TRANSFORMATION : {type(df)}")
                    print(
                            f"TRANSFORMATION RETURN TYPE : "
                            f"{type(df)}"
                        )
            # ==================================
            # GOLD TRANSFORMATIONS
            # ==================================

            if TARGET_NAME.upper() == "GL":

                df = apply_gold_transformations(

                    df=df,

                    target_table=row.TargetTable

                )
                
            print("=" * 80)
            print(f"DF TYPE BEFORE WRITE : {type(df)}")
            print(f"TARGET TABLE : {row.TargetTable}")
            print("=" * 80)

            rows_written = df.count()


                    f"{dependency_task_id}"
                )

                print("=" * 70)

                continue

        # ======================================
        # SKIP SUCCESS TASKS
        # ======================================

        if restart_flag == 1:

            success_df = spark.sql(f"""

            SELECT COUNT(*)

            FROM meta.TaskQueue

            WHERE RunId = {RUN_ID}

            AND TaskConfigId =
                {row.TaskConfigId}

            AND Status = 'SUCCESS'

            """)

            already_success = (
                success_df.collect()[0][0]
            )

            if already_success > 0:

                print("=" * 70)

                print(
                    f"SKIPPING : "
